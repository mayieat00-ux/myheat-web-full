# Browser-side API base. Relative path lets the Next.js rewrite proxy /api/v1/*
# to the backend, so phones on your LAN only need to reach port 3001 (not 4000).
# In production, set this to your backend's public URL.
NEXT_PUBLIC_API_URL="/api/v1"

# Auth.js secret (used to sign session cookies).
NEXTAUTH_SECRET="change-me-to-a-strong-random-string-32-chars-min"

# NEXTAUTH_URL is intentionally NOT set in dev — Auth.js v5 auto-detects the
# origin from the request, which means LAN-IP access works the same as localhost.
# Set it only in production to your canonical site URL.

# Google OAuth credentials. Leave blank to use only the dev-login bypass.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
