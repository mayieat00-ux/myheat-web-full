# Public API base. The API is embedded in the Next.js app, so a relative URL
# works for both the browser and the dev server.
NEXT_PUBLIC_API_URL="/api/v1"

# Auth.js secret (used to sign session cookies). Auth.js v5 reads AUTH_SECRET;
# NEXTAUTH_SECRET is accepted as a fallback for legacy setups.
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-strong-random-string-32-chars-min"

# Google OAuth credentials. Leave blank to use only the dev-login bypass.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# PostgreSQL connection string. Also used by Prisma — must be present in .env
# (or the shell) when running Prisma CLI commands such as `npx prisma migrate`.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mayieat?schema=public"

# JWT used by the embedded API to sign bearer tokens after Google OAuth.
# Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-another-strong-random-string"

# Google Gemini (optional, for future AI features).
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
