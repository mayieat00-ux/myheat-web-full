# Canonical public URL where this app is hosted (no trailing slash).
# Auth.js uses this to generate the Google OAuth redirect URI.
# Example: https://app.mayieat.com
AUTH_URL=https://app.mayieat.com

# Auth.js session cookie secret. Generate a strong random value:
#   openssl rand -base64 32
AUTH_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# Google OAuth credentials from Google Cloud Console.
GOOGLE_CLIENT_ID=replace_with_your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=replace_with_your_client_secret

# PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/mayieat?schema=public

# Secret used by the embedded API to sign the backend JWT.
# Generate a different random value from AUTH_SECRET.
JWT_SECRET=replace_with_another_strong_random_secret

# Optional: Gemini API key for AI-powered scan results.
GEMINI_API_KEY=optional
GEMINI_MODEL=gemini-2.5-flash
