# ============================================================
# MayiEat — environment variable template
# Copy to .env in the appropriate workspace and fill in real values
# ============================================================

# ----- Database (PostgreSQL) -----
# Example: postgresql://user:password@localhost:5432/mayieat
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mayieat?schema=public"

# ----- Backend -----
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# JWT used by backend to sign session tokens (after Google OAuth bridge)
# Generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-strong-random-string"

# ----- Google OAuth -----
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----- Google Gemini -----
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ----- Frontend (Next.js / Auth.js) -----
# Same Google credentials reused by Auth.js
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-another-strong-random-string"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
