// MayiEat — database schema
// Run: npm run prisma:migrate after editing.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================
enum Sex {
  MALE
  FEMALE
  OTHER
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum Goal {
  LOSE
  MAINTAIN
  GAIN
}

enum ScanMethod {
  BARCODE
  IMAGE
}

enum FoodSource {
  BARCODE
  AI_VISION
  MANUAL
}

enum NutriGrade {
  A
  B
  C
  D
  E
}

enum SubscriptionPlan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

enum SubscriptionSource {
  DEFAULT
  MANUAL_GRANT
  STRIPE_FUTURE
}

enum AIFeature {
  IMAGE_SCAN
  RATING_EXPLANATION
  DIET_PLAN
}

enum DietPeriodType {
  DAILY
  WEEKLY
}

// ============================================================
// Models
// ============================================================
model User {
  id        String   @id @default(cuid())
  googleId  String   @unique
  email     String   @unique
  name      String?
  image     String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile      UserProfile?
  subscription Subscription?
  scans        Scan[]
  dailyLogs    DailyLog[]
  dietPlans    DietPlan[]
  aiUsage      AIUsage[]

  @@index([email])
}

model UserProfile {
  id                 String        @id @default(cuid())
  userId             String        @unique
  age                Int
  sex                Sex
  heightCm           Float
  weightKg           Float
  activityLevel      ActivityLevel
  goal               Goal
  allergies          String[]
  dietaryPrefs       String[]
  medicalFlags       String[]
  dailyCalorieTarget Int?
  updatedAt          DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Food {
  id              String      @id @default(cuid())
  source          FoodSource
  barcode         String?     @unique
  name            String
  brand           String?
  imageUrl        String?
  nutrients       Json
  ingredients     String?
  additives       String[]
  nutriScoreGrade NutriGrade?
  nutriScoreValue Int?
  rawPayload      Json?
  createdAt       DateTime    @default(now())

  scans        Scan[]
  healthRating HealthRating?

  @@index([name])
}

model HealthRating {
  id        String     @id @default(cuid())
  foodId    String     @unique
  baseScore Int
  baseGrade NutriGrade
  updatedAt DateTime   @updatedAt

  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade)
}

model Scan {
  id                 String     @id @default(cuid())
  userId             String
  foodId             String
  method             ScanMethod
  imageUrl           String?
  personalizedRating Json
  createdAt          DateTime   @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
}

model DietPlan {
  id          String         @id @default(cuid())
  userId      String
  periodType  DietPeriodType
  periodStart DateTime
  content     Json
  model       String
  createdAt   DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodStart, periodType])
}

model DailyLog {
  id      String   @id @default(cuid())
  userId  String
  date    DateTime @db.Date
  entries Json
  totals  Json

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  source             SubscriptionSource @default(DEFAULT)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AIUsage {
  id        String    @id @default(cuid())
  userId    String
  feature   AIFeature
  weekKey   String // ISO week, e.g. "2026-W22"
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, weekKey])
}
